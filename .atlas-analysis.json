  "keyFeatures": [
    "JWT Authentication with access and refresh tokens",
    "Role-Based Access Control (RBAC) with Admin and User roles",
    "Full CRUD task management with status and priority tracking",
    "Tag system for task categorization with custom colors",
    "Advanced filtering by status, priority, tags, and date ranges",
    "Server-side pagination and customizable sorting",
    "Data export to CSV and JSON formats",
    "Rate limiting with Flask-Limiter",
    "Interactive Swagger/OpenAPI documentation",
    "268 tests with >73% code coverage",
    "Azure App Service deployment with CI/CD via GitHub Actions",
    "Docker support with Docker Compose"
  ],
  "publicApiSurface": [
